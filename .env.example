# Enterprise Insight RAG v1.0 - Environment Variables Template
# Copy this file to .env and update with your actual values
# WARNING: Never commit .env file to Git!

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_DB=enterprise_rag
POSTGRES_USER=rag_admin
# WARNING: Change this password in production! Use 16+ characters with mixed case, numbers, and symbols
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password_123!

# ============================================================================
# Neo4j Configuration
# ============================================================================
# WARNING: Change this password in production! Use 16+ characters with mixed case, numbers, and symbols
NEO4J_PASSWORD=CHANGE_ME_strong_neo4j_password_456!

# ============================================================================
# Redis Configuration
# ============================================================================
# WARNING: Change this password in production! Use 16+ characters with mixed case, numbers, and symbols
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_789!

# ============================================================================
# JWT Configuration (for Phase 3 - Authentication Service)
# ============================================================================
# WARNING: Change this secret in production! Use 32+ characters random string
JWT_SECRET=CHANGE_ME_jwt_secret_key_with_32_plus_characters_abc!
# JWT token expiration in seconds (3600 = 1 hour)
JWT_EXPIRATION=3600

# ============================================================================
# Service Ports (for Phase 3+ - Application Services)
# ============================================================================
# Java Authentication Service port
API_PORT=8080
# Python AI Service port
AI_SERVICE_PORT=8000

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
# Environment: development, staging, production
ENVIRONMENT=development
